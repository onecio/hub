# =============================================================================
# HUB Institucional CADE — Variáveis de Ambiente
# Copie para .env e preencha os valores ANTES de iniciar os containers.
# Nunca comite o arquivo .env no repositório.
# Gere segredos com: openssl rand -hex 32
# =============================================================================

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Servidor backend ──────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Domínio (usado pelo Caddy para TLS automático) ───────────────────────────
# Em desenvolvimento local: use "localhost" e adicione "local_certs" no Caddyfile
DOMAIN=hub.cade.gov.br
ADMIN_EMAIL=admin@cade.gov.br

# ── Banco de dados ────────────────────────────────────────────────────────────
# Deve apontar para o volume montado em /app/data
DB_PATH=/app/data/hub.db

# ── JWT (gerar com: openssl rand -hex 32) ─────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32_different
JWT_REFRESH_EXPIRES=7d

# ── Sessão (gerar com: openssl rand -hex 32) ──────────────────────────────────
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── CSRF (gerar com: openssl rand -hex 32) ────────────────────────────────────
CSRF_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Criptografia em repouso (AES-256-GCM, gerar com: openssl rand -hex 32) ────
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────────────────
# Separar múltiplos origins com vírgula
CORS_ORIGINS=https://hub.cade.gov.br

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.cade.gov.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cade.gov.br
SMTP_PASS=CHANGE_ME
SMTP_FROM="HUB CADE <noreply@cade.gov.br>"

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/backups

# ── Monitoramento ─────────────────────────────────────────────────────────────
MONITOR_DEFAULT_INTERVAL=60
MONITOR_DEFAULT_TIMEOUT_MS=10000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Habilitar pretty-print apenas em desenvolvimento (false em produção)
LOG_PRETTY=true

# ── Métricas Prometheus (token de autenticação Bearer) ────────────────────────
METRICS_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Webhooks (assinatura HMAC-SHA256) ─────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
