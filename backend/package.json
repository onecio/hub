{
  "name": "hub-institucional-backend",
  "version": "0.1.0",
  "description": "Backend do HUB Institucional CADE — Fastify + SQLite",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.7.0",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.8.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "vitest": "^4.1.6"
  },
  "vitest": {
    "globals": true,
    "environment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "json",
        "html"
      ],
      "exclude": [
        "node_modules/**",
        "tests/**",
        "src/healthcheck.js"
      ]
    }
  }
}
